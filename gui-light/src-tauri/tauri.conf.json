{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "TrustTunnel Light",
  "version": "1.0.0",
  "identifier": "com.trusttunnel.light",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TrustTunnel Light v1.0.0",
        "width": 420,
        "height": 680,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "trusttunnel_client"
    ],
    "resources": [
      "wintun.dll"
    ],
    "windows": {
      "allowDowngrades": true
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
