{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "TrustTunnel Client Light",
  "version": "2.6.0",
  "identifier": "com.trusttunnel.light",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TrustTunnel Client for Windows Light v2.6.0",
        "width": 420,
        "height": 680,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "trusttunnel_client"
    ],
    "resources": [
      "wintun.dll",
      "vcruntime140.dll",
      "vcruntime140_1.dll"
    ],
    "windows": {
      "allowDowngrades": true,
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsh",
        "languages": ["Russian", "English"],
        "displayLanguageSelector": false,
        "customLanguageFiles": {
          "Russian": "nsis/Russian.nsh",
          "English": "nsis/English.nsh"
        }
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
